{
  "name": "instagram-login",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "server": "node server/index.js",
    "build": "tsc -b && vite build",
    "build:netlify": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "netlify:dev": "netlify dev"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "framer-motion": "^12.42.2",
    "git": "^0.1.5",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serverless-http": "^3.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.0",
    "netlify-cli": "^23.0.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.20.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
